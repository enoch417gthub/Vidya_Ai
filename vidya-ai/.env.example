# ============================================================
# VIDYA AI — .env.example
# Copy to .env and fill in your values
# cp .env.example .env
# ============================================================
# --- APPLICATION ---
APP_NAME=VIDYA AI
APP_VERSION=1.0.0
DEBUG=False
# --- SERVER ---
API_HOST=127.0.0.1 # Always localhost — never expose externally
API_PORT=8000
# --- PATHS ---
MODELS_DIR=./models
KNOWLEDGE_BASE_DIR=./knowledge_base
DATABASE_PATH=./database/vidya.db
EXPORTS_DIR=./exports
# --- LLM CONFIG ---
LLM_MODEL_FILENAME=Meta-Llama-3-8B-Instruct-Q4_K_M.gguf
LLM_N_CTX=4096 # Context window size (tokens)
LLM_N_THREADS=4 # CPU threads for inference
LLM_MAX_TOKENS=512 # Max tokens per response
LLM_TEMPERATURE=0.3 # Lower = more focused, less creative
# --- EMBEDDING CONFIG ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# --- RETRIEVAL CONFIG ---
RETRIEVAL_TOP_K=6 # Number of chunks to retrieve per query
CHUNK_SIZE=512 # Tokens per chunk
CHUNK_OVERLAP=50 # Overlap between consecutive chunks
# --- ADMIN ---
ADMIN_PASSWORD_HASH= # Run scripts/set_admin_password.py to set
# --- LANGUAGE ---
DEFAULT_LANGUAGE=en # en, hi, ta, te, kn, bn, mr, gu